{
  "expo": {
    "name": "Frankie Fit",
    "slug": "frankie-fit-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "frankiefit",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.michaeldito.frankiefit",
      "infoPlist": {
        "NSHealthShareUsageDescription": "Frankie Fit reads Apple Health workouts, heart rate, energy, and distance to help summarize training and recovery context.",
        "NSHealthUpdateUsageDescription": "Frankie Fit does not write health data."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#07172f",
          "dark": {
            "backgroundColor": "#07172f"
          }
        }
      ],
      "expo-sqlite",
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "Frankie Fit reads Apple Health workouts, heart rate, energy, and distance to help summarize training and recovery context.",
          "NSHealthUpdateUsageDescription": "Frankie Fit does not write health data.",
          "background": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
