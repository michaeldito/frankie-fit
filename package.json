    "lint:web": "eslint .",
    "dev:mobile": "pnpm --dir apps/mobile start",
    "ios:mobile": "pnpm --dir apps/mobile ios",
    "android:mobile": "pnpm --dir apps/mobile android",
    "web:mobile": "pnpm --dir apps/mobile web",
    "lint:mobile": "pnpm --dir apps/mobile lint"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.3",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.4",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3"
  }
